<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dashboardFragment">

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.familyhealth.medicinetracker.presentation.ui.dashboard.DashboardFragment"
        android:label="Today"
        tools:layout="@layout/fragment_dashboard"
        xmlns:tools="http://schemas.android.com/tools">

        <action
            android:id="@+id/action_dashboard_to_addMedicine"
            app:destination="@id/addMedicineFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/addMedicineFragment"
        android:name="com.familyhealth.medicinetracker.presentation.ui.addmedicine.AddMedicineFragment"
        android:label="Add Medicine"
        tools:layout="@layout/fragment_add_medicine"
        xmlns:tools="http://schemas.android.com/tools" />

</navigation>
